@startuml SyncFlow System Architecture

' ================== 레이아웃 ==================
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundCorner 20

' ================== 공통 스타일 ==================
skinparam arrow {
  Color #7F8C8D
  FontColor #2C3E50
  FontSize 11
}

skinparam defaultTextAlignment center

skinparam rectangle {
  BorderColor #2C3E50
  FontColor #2C3E50
  FontSize 12
}

' ================== APP ==================
rectangle "📱 APP\n\n**SyncFlow**\n\nFlutter\nState Management:\n**Riverpod**" as App #E8F4FD

' ================== LOCAL STORAGE ==================
rectangle "⚙️ GetStorage\n\n- theme_mode\n- locale\n- wakelock\n- tutorial_done" as Storage #FDEDEC

rectangle "🔐 SecureStorage\n\n- session_token" as SecureStorage #E8F5E9

' ================== BACKEND ==================
rectangle "☁️ FastAPI\n\nREST:\n/v1/auth\n/v1/boards\n/v1/cards\n\nWebSocket:\n/ws" as API #E8F5E9

database "MySQL\n\nsyncflow_db\n- users\n- email_verifications\n- sessions\n- boards\n- board_members\n- columns\n- cards\n- board_invites" as MySQL #E3F2FD

' ================== 연결 ==================
App --> Storage : Preferences\n(AppStorage)
App --> SecureStorage : Session Token\n(SessionSecureStorage)
App --> API : REST + WebSocket\n(ApiClient, WsService)
API --> MySQL : CRUD

@enduml
